# Database Configuration
DATABASE_URL=sqlite:///misinformation.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/misinfo_db

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Model Paths
MISINFO_MODEL_PATH=../models/misinfo_model
STANCE_MODEL_PATH=../models/stance_model
BOT_MODEL_PATH=../models/bot_model.joblib

# Upload Configuration
UPLOAD_FOLDER=../data/uploads
MAX_CONTENT_LENGTH=16777216
